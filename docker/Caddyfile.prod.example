# Production GUI proxy: wildcard subdomain per instance instead of a dev port.
# Caddy gets a real wildcard TLS cert (DNS-01) for *.gui.example.com, so the
# browser sees a valid cert and a clean per-instance origin. Each subdomain
# reverse-proxies to that instance's in-container tunnel forwarder (backend:PORT,
# set via DASH_GUI_TUNNELS). Map gui-<id> -> the matching port.
#
# SECURITY: this exposes a firewall admin GUI per origin. Gate it — e.g. Caddy
# forward_auth to the dashboard's session before proxying — do NOT ship it open.

*.gui.example.com {
	tls {
		dns cloudflare {env.CF_API_TOKEN}   # or your DNS provider
	}

	@inst3 host gui-3.gui.example.com
	reverse_proxy @inst3 https://backend:14444 {
		transport http {
			tls_insecure_skip_verify
		}
	}
	# ... one block per instance, or template via a map ...
}
