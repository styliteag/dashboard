# Production GUI proxy: wildcard subdomain per instance instead of a dev port.
# Caddy gets a real wildcard TLS cert (DNS-01) for *.gui.example.com, so the
# browser sees a valid cert + a clean per-instance origin. Same auth gate as dev
# (handoff -> orbit_gui cookie -> forward_auth). The per-instance forwarder port is
# 14400+id (backend GuiTunnelManager); map the subdomain label to it.
#
# SECURITY: each origin fronts a firewall admin GUI — the forward_auth gate is what
# keeps it closed. Do NOT remove it.

*.gui.example.com {
	tls {
		dns cloudflare {env.CF_API_TOKEN}   # your DNS provider, for the wildcard cert
	}

	# Map the gui-<id> label to that instance's id + forwarder port. Extend per
	# instance, or drive Caddy's admin API from the backend for true on-demand.
	map {labels.3} {orbit.id} {orbit.port} {
		gui-3 3 14403
		gui-4 4 14404
	}

	@orbit path /__orbit/*
	handle @orbit {
		rewrite * /api/gui/handoff?{query}
		reverse_proxy backend:8000
	}
	handle {
		forward_auth backend:8000 {
			uri /api/gui/authcheck?instance={orbit.id}
		}
		reverse_proxy https://backend:{orbit.port} {
			transport http {
				tls_insecure_skip_verify
			}
		}
	}
}

# The dashboard itself sets DASH_GUI_BASE_TEMPLATE="https://gui-{id}.gui.example.com"
# so POST /gui/open returns the right per-instance origin.
