# Frontend dev image: Vite dev server with HMR. Source bind-mounted at runtime.
FROM node:20-alpine

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

# Source (overridden by bind mount in compose-dev)
COPY . ./

EXPOSE 5173

# --host 0.0.0.0 makes the dev server reachable from outside the container.
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
