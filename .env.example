# Copy to .env and fill in real values. Never commit .env.

# --- Database (MariaDB 11) ---
DB_USER=dash
DB_PASSWORD=change-me-strong-random
DB_ROOT_PASSWORD=change-me-root-strong-random
DB_NAME=dash

# --- Backend ---
DASH_ENV=prod
DASH_LOG_LEVEL=info

# Generate with: just gen-key
DASH_MASTER_KEY=

# Initial admin password (only used on first start when no admin exists yet)
DASH_ADMIN_PASSWORD=change-me-on-first-login

# Default per-instance poll cadence for direct-API devices (seconds); an
# instance can override it in the UI. The scheduler ticks every
# DASH_POLL_TICK_SECONDS and polls each instance once its interval is due.
DASH_POLL_INTERVAL_SECONDS=30
DASH_POLL_TICK_SECONDS=10
DASH_POLL_CONCURRENCY=20

# Default agent push cadence (seconds) sent to push-mode agents; an instance
# can override it in the UI (applied live on the agent's next push).
DASH_PUSH_INTERVAL_SECONDS=30

# --- Notifications (all optional) ---
# Webhook: POST JSON with {title, message, level} to this URL
DASH_NOTIFY_WEBHOOK_URL=
# Telegram bot: token + chat ID
DASH_NOTIFY_TELEGRAM_TOKEN=
DASH_NOTIFY_TELEGRAM_CHAT_ID=
# ntfy: topic URL (e.g. https://ntfy.sh/my-opnsense)
DASH_NOTIFY_NTFY_URL=

# --- Public bind port (host -> container :80) ---
DASH_PORT=80

# --- Optional: pass through to frontend build (Vite) ---
# VITE_API_BASE_URL=

# Firewall GUI proxy (OPTIONAL). Off by default — needs a reverse proxy giving
# each firewall a per-instance origin (Caddy/port in dev, Traefik/wildcard in
# prod). See README "Firewall GUI proxy". Leave disabled if you don't set that up.
DASH_GUI_PROXY_ENABLED=false
# Per-instance origin template (prod). {slug} = instance slug (persistent, URL-safe;
# {id} also accepted for back-compat). Empty -> dev default https://localhost:900{id}.
# Prod e.g.:
# DASH_GUI_BASE_TEMPLATE=https://gui-{slug}.gui.example.com
DASH_GUI_BASE_TEMPLATE=
# Prod only: wildcard base for the `gui-proxy` Caddy (compose --profile gui).
# Your external Traefik routes *.${ORBIT_GUI_DOMAIN} to it.
# ORBIT_GUI_DOMAIN=gui.example.com
# Caddy admin endpoint the backend hot-loads the per-slug vhost map to. REQUIRED
# when the prod proxy is enabled: if unset, the push silently no-ops and every
# gui-<slug> host returns a blank 200. The bundled compose.yml defaults this for
# you; a hand-written compose / Swarm stack must set it explicitly.
# DASH_GUI_CADDY_ADMIN_URL=http://gui-proxy:2019/load
# Close an instance forwarder after N idle minutes (0 disables).
DASH_GUI_IDLE_MINUTES=15
