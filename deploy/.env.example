# Copy to deploy/.env and fill in real values. Never commit deploy/.env.

# --- Database ---
POSTGRES_USER=dash
POSTGRES_PASSWORD=change-me-strong-random
POSTGRES_DB=dash

# --- Backend ---
DASH_ENV=prod
DASH_LOG_LEVEL=info

# Generate with:
#   python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
DASH_MASTER_KEY=

# Initial admin password (only used on first start when no admin exists yet)
DASH_ADMIN_PASSWORD=change-me-on-first-login

DASH_POLL_INTERVAL_SECONDS=30
DASH_POLL_CONCURRENCY=20

# --- Notifications (all optional) ---
# Webhook: POST JSON with {title, message, level} to this URL
DASH_NOTIFY_WEBHOOK_URL=
# Telegram bot: token + chat ID
DASH_NOTIFY_TELEGRAM_TOKEN=
DASH_NOTIFY_TELEGRAM_CHAT_ID=
# ntfy: topic URL (e.g. https://ntfy.sh/my-opnsense)
DASH_NOTIFY_NTFY_URL=

# --- Caddy / public hostname ---
# Use ":80" for local plain HTTP, or a real hostname for auto-TLS via Let's Encrypt.
DASH_DOMAIN=:80
